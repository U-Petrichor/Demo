root = true

[*.cs]
dotnet_diagnostic.IDE0017.severity = none
csharp_prefer_object_initializer = false:silent
dotnet_diagnostic.IDE0090.severity = none
csharp_style_prefer_target_typed_new = false:silent
dotnet_diagnostic.IDE0056.severity = none
csharp_style_prefer_index_operator = false:silent
csharp_style_prefer_range_operator = false:silent
dotnet_diagnostic.IDE0251.severity = none
dotnet_style_readonly_field = false:silent
